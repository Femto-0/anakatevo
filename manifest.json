{
    "manifest_version": 3, 
    "name": "Anakatevo",
    "version": "1.0",
    "description":"A simple extension to get rid of metadata",

    "action": {
        "default_title": "A simple extension to get rid of metadata",
        "default_icon": {
            "16":"icons/icon-16.png",
            "48":"icons/icon-48.png",
            "128": "icons/icon-128.png"
        },
        "default_popup": "anakatevo.html"
    },
    "icons": {
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "browser_specific_settings":{
        "gecko": {
            "id": "anakatevo@ritesh",
            "data_collection_permissions":{
                "required": ["none"]
            }
        }
    }
    
}
